    public static class MCTSNode
        extends Node
    {
        public MCTSNode(final GameView game,
                        final int logicalPlayerIdx,
                        final Node parent)
        {
            super(game, logicalPlayerIdx, parent);
        }
        
        @Override
        public Node getChild(final Move move)
        {
            GameView gameView = this.getGameView();
            //Creating rando agents, and adding them to make a new game instance
            Agent[] agentList = new Agent[gameView.getNumPlayers()];
            for(int i = 0; i < gameView.getNumPlayers(); i++) {
                int agentIdx = gameView.getPlayerOrder().getAgentIdx(i);
                //Set thinking time to 5000 for now. Might need to change
                RandomAgent a = new RandomAgent(agentIdx, 5000);
                a.setLogicalPlayerIdx(i);
                agentList[i] = a;
            }
            Game game = new Game(gameView, agentList);
            int curLogicalIdx = game.getPlayerOrder().getCurrentLogicalPlayerIdx();
            Agent curAgent = game.getAgent(curLogicalIdx);
            NodeState curState = getNodeState();
            Move newMove = null;
            if(curState.equals(NodeState.NO_LEGAL_MOVES_UNRESOLVED_CARDS_PRESENT)) {
                //Pick up stacked on cards
                game.drawTotal(game.getHand(curLogicalIdx), game.getUnresolvedCards().total());
                game.getUnresolvedCards().clear();
            } else if(curState.equals(NodeState.NO_LEGAL_MOVES_MAY_PLAY_DRAWN_CARD)) {
                //Handle may play drawn card
                int drawnCardIdx = game.getHand(curLogicalIdx).size() - 1;
                // Isnt wild
                if(move.getNewColorIfWild() == null) {
                    newMove = Move.createMove(curAgent, drawnCardIdx);
                } else {
                    // Just set the color as nonCur Color for now, had issues using random and wanted to get this done.
                    ArrayList<Color> colors = new ArrayList<>();
                    colors.add(Color.RED);
                    colors.add(Color.YELLOW);
                    colors.add(Color.GREEN);
                    colors.add(Color.BLUE);
                    Color curColor = gameView.getCurrentColor();
                    colors.remove(curColor);
                    newMove = Move.createMove(curAgent, drawnCardIdx, colors.get(0));
                }
                game.resolveMove(newMove);
            } else {
                // Handle legal moves
                if(move.getNewColorIfWild() == null) {
                    // Isnt wild
                    newMove = Move.createMove(curAgent, move.getCardToPlayIdx());
                } else { 
                    // Is. Set to nonCur rn like the wild selector above.
                    ArrayList<Color> colors = new ArrayList<>();
                    colors.add(Color.RED);
                    colors.add(Color.YELLOW);
                    colors.add(Color.GREEN);
                    colors.add(Color.BLUE);
                    Color curColor = gameView.getCurrentColor();
                    colors.remove(curColor);
                    newMove = Move.createMove(curAgent, move.getCardToPlayIdx(), colors.get(0));
                }
                game.resolveMove(newMove);
            }
            GameView newView = new GameView(game, game.getCurrentAgent().getPlayerIdx());
            return new MCTSNode(newView, curLogicalIdx, this);
        }
    }
