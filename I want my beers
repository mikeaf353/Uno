    public static class MCTSNode
        extends Node
    {
        public MCTSNode(final GameView game,
                        final int logicalPlayerIdx,
                        final Node parent)
        {
            super(game, logicalPlayerIdx, parent);
        }

        @Override
        public Node getChild(final Move move)
        {
            GameView gameView = this.getGameView();
            Agent[] agentList = new Agent[gameView.getNumPlayers()];
            for(int i = 0; i < gameView.getNumPlayers(); i++) {
                int agentIdx = gameView.getPlayerOrder().getAgentIdx(i);
                Agent a = new RandomAgent(agentIdx, 4800);
                a.setLogicalPlayerIdx(i);
                agentList[i] = a;
            }
            HandView hand = gameView.getHandView(getLogicalPlayerIdx());
            Hand h = new Hand(hand);
            List<Card> mycards = h.getCards();

            Stack<Card> discardpile = gameView.getDiscardPile().pile();
            Deck deck = new Deck(true);

            List<Card> cards = new ArrayList<>();
            for(Card c: deck){
                cards.add(c);
            }
            for(Card c : cards) {
                if (discardpile.contains(c) || mycards.contains(c)) {
                    deck.remove(c);
                }
            }
            Random r = new Random();
            Hand[] all_hands = new Hand[gameView.getNumPlayers()];
            all_hands[this.getLogicalPlayerIdx()] = h;
            for(int i = 0; i < gameView.getNumPlayers(); i++){
                if(i == this.getLogicalPlayerIdx()){
                    continue;
                }
                int hand_size = gameView.getHandView(i).size();
                List<Card> cur_hand = new ArrayList<>();
                for(int j = 0; j < hand_size;j++){
                    int random = r.nextInt(deck.size());
                    cur_hand.add(deck.get(random));
                    deck.remove(random);
                }
                HandView uh = new HandView(cur_hand);
                Hand nuh = new Hand(uh);
                all_hands[i] = nuh;
            }

            Game new_game = new Game(deck, all_hands, gameView, agentList);

            if(move != null){
                new_game.resolveMove(move);
            }
            int playerIdx = new_game.getPlayerOrder().getAgentIdx(this.getLogicalPlayerIdx());
            return new MCTSNode(new_game.getView(playerIdx), this.getLogicalPlayerIdx(), this);

        }
    }

